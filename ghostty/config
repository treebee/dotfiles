theme = Catppuccin Mocha
term = xterm-256color

font-family = "MonaspiceAr Nerd Font Mono"
font-size = 12
font-feature = calt
font-feature = liga
font-feature = dlig
font-feature = ss01
font-feature = ss02
font-feature = ss03
font-feature = ss04
font-feature = ss05
font-feature = ss06
font-feature = ss07
font-feature = ss08

#background-opacity = 1
#background-blur = true


# keybindings
keybind = ctrl+shift+n=unbind

# Slowdown mouse scrolling
mouse-scroll-multiplier = 0.95

# Fix general slowness on hyprland (https://github.com/ghostty-org/ghostty/discussions/3224)
async-backend = epoll
